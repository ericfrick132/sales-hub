# /opt/sales-hub/.env on the droplet
# All values consumed by SalesHub.Api (which also runs the BackgroundServices when SALESHUB_RUN_WORKERS=true)

# ===== Postgres (managed cluster dbaas-db-3146727, database "saleshub") =====
ConnectionStrings__Default=Host=dbaas-db-3146727-do-user-23398434-0.e.db.ondigitalocean.com;Port=25060;Database=saleshub;Username=saleshub;Password=REPLACE_ME;SSL Mode=Require;Trust Server Certificate=true

# ===== JWT =====
Jwt__Issuer=sales-hub
Jwt__Audience=sales-hub
Jwt__SigningKey=REPLACE_WITH_RANDOM_STRING_AT_LEAST_32_CHARS

# ===== Apify =====
Apify__Token=apify_api_REPLACE_ME

# ===== Evolution (corre en este mismo droplet) =====
Evolution__BaseUrl=http://evolution-api:8080
Evolution__ApiKey=REPLACE_ME

# ===== Google =====
Google__OAuthClientId=
Google__PlacesApiKey=

# ===== CORS — frontend en GitHub Pages =====
Cors__Origins=https://sales.efcloud.tech

# ===== Seed admin =====
Seed__AdminEmail=eric@efcloud.tech
Seed__AdminPassword=REPLACE_ME
